FORM validate_filename.

  SELECT 'I' AS sign,
         'EQ' AS option,
         zcode_value AS low
    FROM zcode_mstr
    INTO TABLE @r_werks
    WHERE zcode_fldname = 'WAREIQ'.

  IF rb1 = 'X'.

    IF p_fpath1 IS NOT INITIAL.
      CALL METHOD cl_gui_frontend_services=>directory_list_files   "This method is Case Insensitive.
        EXPORTING
          directory                   = p_fpath1
          filter                      = 'SO_*.txt'
          files_only                  = 'X'
        CHANGING
          file_table                  = i_file_table
          count                       = lv_file_count
        EXCEPTIONS
          cntl_error                  = 1
          directory_list_files_failed = 2
          wrong_parameter             = 3
          error_no_gui                = 4
          not_supported_by_gui        = 5
          OTHERS                      = 6.

      IF sy-subrc <> 0.
        MESSAGE 'Error in selecting file' TYPE 'E'.
      ELSEIF i_file_table IS INITIAL.
        MESSAGE 'No Files Found' TYPE 'E'.
      ENDIF.
    ENDIF.

    LOOP AT i_file_table ASSIGNING FIELD-SYMBOL(<fs_file_table>).
      PERFORM createfilename USING <fs_file_table>-filename.
    ENDLOOP.

    IF i_ec_file IS NOT INITIAL.
      INSERT zec_file FROM TABLE i_ec_file.
      COMMIT WORK.
    ENDIF.

  ELSEIF rb2 = 'X'.
    name = p_fpath2.
    len = strlen( name ).
    len = len - 1.
    IF name+len(1) NE '/'.
      CONCATENATE name '/' INTO name.
    ENDIF.

    CALL FUNCTION 'RZL_READ_DIR_LOCAL'
      EXPORTING
        name     = name
      TABLES
        file_tbl = i_files.

    LOOP AT i_files ASSIGNING FIELD-SYMBOL(<fs_files>).
*Unable to read file if filename is changed to upper case in AIX OS.
*      TRANSLATE <fs_files>-name TO UPPER CASE.
      CHECK <fs_files>-name+0(3) = 'SO_'.
      PERFORM createfilename USING <fs_files>-name.
    ENDLOOP.

    IF i_ec_file IS NOT INITIAL.
      INSERT zec_file FROM TABLE i_ec_file.
      COMMIT WORK.
    ENDIF.
  ENDIF.
ENDFORM.
