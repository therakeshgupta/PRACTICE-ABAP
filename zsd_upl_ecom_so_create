*&      Form  CREATEFILENAME
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LV_FILENAME  text
*----------------------------------------------------------------------*
FORM createfilename USING p_lv_filename.

  DATA:
    lv_file_exist TYPE bool,
    lv_date       TYPE sy-datum,
    lv_remarks    TYPE zec_file-remarks,
    lv_filename   TYPE zec_file-filename.


  CLEAR: w_ec_file, lv_file_exist, lv_date, lv_split1, lv_split2, lv_split3, lv_split4.

*  lv_filename = p_lv_filename.
*  TRANSLATE lv_filename TO UPPER CASE.

  SELECT SINGLE @abap_true FROM zec_file
    INTO @lv_file_exist
    WHERE filename = @p_lv_filename.

  CALL FUNCTION 'GUID_CREATE'
    IMPORTING
      ev_guid_16 = w_ec_file-fguid.

  w_ec_file-filename = p_lv_filename.
  w_ec_file-erdat = sy-datum.
  w_ec_file-erzet = sy-uzeit.
  w_ec_file-ernam = sy-uname.

  SPLIT p_lv_filename AT '_' INTO lv_split1 lv_split2 lv_split3 lv_split4.
  lv_date = CONV #( lv_split3 ).

  CALL FUNCTION 'DATE_CHECK_PLAUSIBILITY'
    EXPORTING
      date                      = lv_date
    EXCEPTIONS
      plausibility_check_failed = 1
      OTHERS                    = 2.

  IF sy-subrc NE 0.
    w_ec_file-fstatus = 'FAILED'.
    CONCATENATE w_ec_file-remarks 'Invalid Date,' INTO w_ec_file-remarks SEPARATED BY space.
    CONDENSE w_ec_file-remarks.
  ELSE.
    w_ec_file-filedate = lv_date.
    IF lv_date GT sy-datum.
      w_ec_file-fstatus = 'FAILED'.
      CONCATENATE w_ec_file-remarks 'Future Date,' INTO w_ec_file-remarks SEPARATED BY space.
      CONDENSE w_ec_file-remarks.
    ENDIF.
  ENDIF.

  IF lv_split2 NOT IN r_werks[].
    w_ec_file-fstatus = 'FAILED'.
    CONCATENATE w_ec_file-remarks 'Invalid Plant,' INTO w_ec_file-remarks SEPARATED BY space.
    CONDENSE w_ec_file-remarks.
  ENDIF.

  IF lv_file_exist = 'X'.
    w_ec_file-fstatus = 'FAILED'.
    CONCATENATE w_ec_file-remarks 'Duplicate File,' INTO w_ec_file-remarks SEPARATED BY space.
    CONDENSE w_ec_file-remarks.
  ENDIF.

  IF w_ec_file-remarks IS NOT INITIAL.
    DATA(lv_len) = strlen( w_ec_file-remarks ).
    DATA(lv_last) = lv_len - 1.
    TRY.
        IF w_ec_file-remarks+lv_last(lv_last) = ','.
          w_ec_file-remarks+lv_last(lv_last) = ''.
        ENDIF.
      CATCH cx_root INTO DATA(o_root).
    ENDTRY.
    CONDENSE w_ec_file-remarks.
  ENDIF.

  APPEND w_ec_file TO i_ec_file.
  CLEAR w_ec_file.

ENDFORM.
