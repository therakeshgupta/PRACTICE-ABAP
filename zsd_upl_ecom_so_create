FORM raw_data_upload.

  DATA: w_ec_file TYPE zec_file.
  DATA: lv_head(20) TYPE c.

  IF rb1 = 'X'.

    LOOP AT i_ec_file ASSIGNING FIELD-SYMBOL(<fs_ec_file>) WHERE fstatus = ''.

      filename = p_fpath1 && '\' && <fs_ec_file>-filename.

      CALL FUNCTION 'GUI_UPLOAD'
        EXPORTING
          filename                = filename
          filetype                = 'ASC'
          has_field_separator     = 'X'
        TABLES
          data_tab                = i_file_data
        EXCEPTIONS
          file_open_error         = 1
          file_read_error         = 2
          no_batch                = 3
          gui_refuse_filetransfer = 4
          invalid_type            = 5
          no_authority            = 6
          unknown_error           = 7
          bad_data_format         = 8
          header_not_allowed      = 9
          separator_not_allowed   = 10
          header_too_long         = 11
          unknown_dp_error        = 12
          access_denied           = 13
          dp_out_of_memory        = 14
          disk_full               = 15
          dp_timeout              = 16
          OTHERS                  = 17.

      IF sy-subrc NE 0.
        MESSAGE e000(zcom) WITH 'Error in opening the file'.
      ENDIF.

      DELETE i_file_data WHERE data IS INITIAL.

      LOOP AT i_file_data INTO w_file_data.
*Exclude Header. Header should be in first row. If Header found at other row, file will be ignored.
        lv_head = CONV #( w_file_data-data ).
        CONDENSE lv_head NO-GAPS.
        TRANSLATE lv_head TO UPPER CASE.
        IF sy-tabix EQ 1 AND lv_head+0(13) = 'PORTALORDER#|'.
          CONTINUE.
        ELSEIF sy-tabix EQ 1 AND lv_head+0(13) NE 'PORTALORDER#|'.
          <fs_ec_file>-fstatus = 'FAILED'.
          <fs_ec_file>-remarks = 'Invalid Header Position'.
          CLEAR i_ec_raw_tmp.
          EXIT.
        ENDIF.
        IF sy-tabix NE 1 AND lv_head+0(13) = 'PORTALORDER#|'.
          <fs_ec_file>-fstatus = 'FAILED'.
          <fs_ec_file>-remarks = 'Invalid Header Position'.
          CLEAR i_ec_raw_tmp.
          EXIT.
        ENDIF.

        w_ec_raw-fguid = <fs_ec_file>-fguid.
        CALL FUNCTION 'GUID_CREATE'
          IMPORTING
            ev_guid_16 = w_ec_raw-rguid.

        CONDENSE w_file_data-data NO-GAPS.
        w_ec_raw-rdata = w_file_data-data.
        SPLIT w_file_data-data AT '|' INTO
                w_ec_raw-ecom_po
                w_ec_raw-ecom_po_date
                w_ec_raw-werks
                w_ec_raw-kunwe
                w_ec_raw-matnr
                w_ec_raw-charg
                w_ec_raw-zmeng
                w_ec_raw-meins
                w_ec_raw-rate
                w_ec_raw-ecom_cust
                w_ec_raw-ecom_inv.

        w_ec_raw-erdat = sy-datum.
        w_ec_raw-erzet = sy-uzeit.
        w_ec_raw-ernam = sy-uname.

*Only PO number is changed to upper case, this will help in reporting.
        TRANSLATE w_ec_raw-ecom_po TO UPPER CASE.

        APPEND w_ec_raw TO i_ec_raw_tmp.
        CLEAR: w_file_data, w_ec_raw.
      ENDLOOP.
      IF i_ec_raw_tmp IS NOT INITIAL.
        APPEND LINES OF i_ec_raw_tmp TO i_ec_raw.
        <fs_ec_file>-fstatus = 'UPLOADED'.
        CLEAR i_ec_raw_tmp.
      ELSE.
        IF <fs_ec_file>-remarks IS INITIAL. "Header validation is happening above. If value filled there no need to fill here.
          <fs_ec_file>-fstatus = 'FAILED'.
          <fs_ec_file>-remarks = 'No entries in file'.
        ENDIF.
      ENDIF.
    ENDLOOP.

    MODIFY zec_raw FROM TABLE i_ec_raw.
    MODIFY zec_file FROM TABLE i_ec_file.
    COMMIT WORK.

  ELSEIF rb2 = 'X'.

    LOOP AT i_ec_file ASSIGNING <fs_ec_file> WHERE fstatus = '' AND
                                                   filename+0(3) = 'SO_'.

      CONCATENATE name <fs_ec_file>-filename INTO fname.

      OPEN DATASET fname FOR INPUT IN TEXT MODE ENCODING DEFAULT.

      CHECK ( sy-subrc = 0 ).

      DO.
        READ DATASET fname INTO lv_data.
        IF sy-subrc EQ 0.

*Exclude Header. Header should be in first row. If Header found at other row file will be ignored.
          lv_head = CONV #( lv_data ).
          CONDENSE lv_head NO-GAPS.
          TRANSLATE lv_head TO UPPER CASE.
          IF sy-index EQ 1 AND lv_head+0(13) = 'PORTALORDER#|'.
            CONTINUE.
          ELSEIF sy-index EQ 1 AND lv_head+0(13) NE 'PORTALORDER#|'.
            <fs_ec_file>-fstatus = 'FAILED'.
            <fs_ec_file>-remarks = 'Invalid Header Position'.
            CLEAR i_ec_raw_tmp.
            EXIT.
          ENDIF.
          IF sy-index NE 1 AND lv_head+0(13) = 'PORTALORDER#|'.
            <fs_ec_file>-fstatus = 'FAILED'.
            <fs_ec_file>-remarks = 'Invalid Header Position'.
            CLEAR i_ec_raw_tmp.
            EXIT.
          ENDIF.

          w_ec_raw-fguid = <fs_ec_file>-fguid.

          CALL FUNCTION 'GUID_CREATE'
            IMPORTING
              ev_guid_16 = w_ec_raw-rguid.

          CONDENSE lv_data NO-GAPS.
          w_ec_raw-rdata = lv_data.

          REPLACE ALL OCCURRENCES OF cl_abap_char_utilities=>cr_lf(1) IN lv_data WITH ''.

          FIND ALL OCCURRENCES OF '|' IN lv_data MATCH COUNT lv_count.
          SPLIT lv_data AT '|' INTO w_ec_raw-ecom_po
                                    w_ec_raw-ecom_po_date
                                    w_ec_raw-werks
                                    w_ec_raw-kunwe
                                    w_ec_raw-matnr
                                    w_ec_raw-charg
                                    w_ec_raw-zmeng
                                    w_ec_raw-meins
                                    w_ec_raw-rate
                                    w_ec_raw-ecom_cust
                                    w_ec_raw-ecom_inv.

          w_ec_raw-erdat = sy-datum.
          w_ec_raw-erzet = sy-uzeit.
          w_ec_raw-ernam = sy-uname.

*Only PO number is changed to upper case, this will help in reporting.
          TRANSLATE w_ec_raw-ecom_po TO UPPER CASE.

          APPEND w_ec_raw TO i_ec_raw_tmp.
          CLEAR : w_ec_raw.
        ELSE.
          EXIT.
        ENDIF.
      ENDDO.
      CLOSE DATASET fname.
      IF i_ec_raw_tmp IS NOT INITIAL.
        APPEND LINES OF i_ec_raw_tmp TO i_ec_raw.
        <fs_ec_file>-fstatus = 'UPLOADED'.
        CLEAR i_ec_raw_tmp.
      ELSE.
        IF <fs_ec_file>-remarks IS INITIAL. "Header validation is happening above. If value filled there no need to fill here.
          <fs_ec_file>-fstatus = 'FAILED'.
          <fs_ec_file>-remarks = 'No Entries in file'.
        ENDIF.
      ENDIF.
    ENDLOOP.

    MODIFY zec_raw FROM TABLE i_ec_raw.
    MODIFY zec_file FROM TABLE i_ec_file.
    COMMIT WORK.

*File Archive
    LOOP AT i_files INTO w_files WHERE name+0(3) = 'SO_'.

      CONCATENATE name w_files-name INTO fname.
      sourcepath = fname.
      CONCATENATE name 'archive/'  w_files-name INTO targetpath.

      CALL FUNCTION 'ARCHIVFILE_SERVER_TO_SERVER'
        EXPORTING
          sourcepath       = sourcepath
          targetpath       = targetpath
        EXCEPTIONS
          error_file       = 1
          no_authorization = 2
          OTHERS           = 3.

      IF sy-subrc EQ 0.
        DELETE DATASET fname.
      ENDIF.
    ENDLOOP.
  ENDIF.
ENDFORM.
