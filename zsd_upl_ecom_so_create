          CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'
            EXPORTING
              wait = 'X'.

          CLEAR: i_ec_mast_tmp, w_ec_log, i_ec_log.
          LOOP AT i_ec_mast ASSIGNING <fs_ec_mast> WHERE ecom_po = w_po_div-ecom_po
                                                     AND werks   = w_po_div-werks   "Santosh CI# INC0105527
                                                     AND mblnr IS NOT INITIAL.

            READ TABLE i_mara INTO w_mara WITH KEY matnr = <fs_ec_mast>-matnr
                                                   spart = w_po_div-spart.
            IF sy-subrc EQ 0.
              <fs_ec_mast>-vbeln_vf = w_success-bill_doc.
              <fs_ec_mast>-status_vf = 'SUCCESS'.
              <fs_ec_mast>-aedat = sy-datum.
              <fs_ec_mast>-aezet = sy-uzeit.
              <fs_ec_mast>-aenam = sy-uname.
              APPEND <fs_ec_mast> TO i_ec_mast_tmp.
            ENDIF.
          ENDLOOP.

          MODIFY zec_data FROM TABLE i_ec_mast_tmp.
          COMMIT WORK AND WAIT.

        ELSE.
*If Invoice creation is failed capture messages for log display.
          CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.

          CALL FUNCTION 'GUID_CREATE'
            IMPORTING
              ev_guid_16 = g_guid.

          CLEAR: w_ec_log, i_ec_mast_tmp.
          LOOP AT i_ec_mast ASSIGNING <fs_ec_mast> WHERE ecom_po = w_po_div-ecom_po
                                                     AND werks   = w_po_div-werks.    "Santosh CI# INC0105527
            READ TABLE i_mara INTO w_mara WITH KEY matnr = <fs_ec_mast>-matnr
                                                   spart = w_po_div-spart.
            IF sy-subrc EQ 0.
              g_fguid = <fs_ec_mast>-fguid.
              <fs_ec_mast>-status_vf = 'FAILED'.
              <fs_ec_mast>-error_vf = g_guid.
              <fs_ec_mast>-aedat = sy-datum.
              <fs_ec_mast>-aezet = sy-uzeit.
              <fs_ec_mast>-aenam = sy-uname.
              APPEND <fs_ec_mast> TO i_ec_mast_tmp.
            ENDIF.
          ENDLOOP.

          w_ec_log-fguid = g_fguid.
          w_ec_log-eguid = g_guid.
          LOOP AT i_return_bill INTO DATA(w_ret_bill) WHERE type = 'E' OR
                                                            type = 'W' OR
                                                            type = 'I'.

            CALL FUNCTION 'GUID_CREATE'
              IMPORTING
                ev_guid_16 = g_guid2.

            CLEAR g_msg.
            CALL FUNCTION 'MESSAGE_TEXT_BUILD'
              EXPORTING
                msgid               = w_ret_bill-id
                msgnr               = w_ret_bill-number
                msgv1               = w_ret_bill-message_v1
                msgv2               = w_ret_bill-message_v2
                msgv3               = w_ret_bill-message_v3
                msgv4               = w_ret_bill-message_v4
              IMPORTING
                message_text_output = g_msg.

            w_ec_log-erguid = g_guid2.
            w_ec_log-remarks = g_msg.
            APPEND w_ec_log TO i_ec_log.
          ENDLOOP.

          MODIFY zec_data FROM TABLE i_ec_mast_tmp.
          MODIFY zec_log FROM TABLE i_ec_log.
          COMMIT WORK AND WAIT.
          CLEAR: i_return_bill[].
          CLEAR: g_guid.
          CLEAR: g_sales_ord, g_delivery, g_pgidoc, g_invoice.
          CONTINUE.
        ENDIF.
      ENDIF.
      CLEAR: w_success.         "MOD01(+)
      CLEAR: g_guid.
      CLEAR: g_sales_ord, g_delivery, g_pgidoc, g_invoice, w_po_div.
*      ENDIF.
    ENDLOOP.
  ENDIF.
ENDFORM.
