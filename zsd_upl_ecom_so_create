FORM send_mail USING p_i_ec_file.

  DATA lv_subject TYPE so_obj_des.

  TRY.
      "Create send request
      DATA(lo_send_request) = cl_bcs=>create_persistent( ).

      "Create mail body
      DATA(lt_body) = VALUE bcsy_text(
                        ( line = 'Dear Recipient,' ) ( )
                        ( line = 'Please find below attachment for uploaded details:.' )
                        ( line = 'Thank You.' )
                      ).

      lv_subject = |ECOM Order upload status in SAP|.

      "Set up document object
      DATA(lo_document) = cl_document_bcs=>create_document(
                            i_type = 'RAW'
                            i_text = lt_body
                            i_subject = lv_subject ).

      PERFORM prepare_attachment CHANGING wa_xstring.

      "Add attachment
      lo_document->add_attachment(
          i_attachment_type    = 'xls'
          i_attachment_size    = CONV #( xstrlen( wa_xstring ) )
          i_attachment_subject = 'Upload Details'
          i_attachment_header  = VALUE #( ( line = 'Report.xlsx' ) )
          i_att_content_hex    = cl_bcs_convert=>xstring_to_solix( wa_xstring )
       ).

      "Add document to send request
      lo_send_request->set_document( lo_document ).

*Set Sender
      DATA: lo_sender TYPE REF TO if_sender_bcs VALUE IS INITIAL.
      lo_sender = cl_sapuser_bcs=>create( sy-uname ). "sender is the logged in user
      lo_send_request->set_sender(
      EXPORTING
      i_sender = lo_sender ).

      SELECT SINGLE zcode_value FROM zcode_mstr
        INTO @DATA(lv_recepient) WHERE zcode_fldname = 'ZECOM01_MAILID'.

      "Set Recipient | This method has options to set CC/BCC as well
      lo_send_request->add_recipient(
        i_recipient = cl_cam_address_bcs=>create_internet_address(
                        i_address_string = CONV #( lv_recepient )
                      )
        i_express   = abap_true ).
      "Send Email
      DATA(lv_sent_to_all) = lo_send_request->send( ).
      COMMIT WORK.

    CATCH cx_send_req_bcs INTO DATA(lx_req_bsc).
      "Error handling
    CATCH cx_document_bcs INTO DATA(lx_doc_bcs).
      "Error handling
    CATCH cx_address_bcs  INTO DATA(lx_add_bcs).
      "Error handling

  ENDTRY.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  PREPARE_ATTACHMENT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      <--P_WA_XSTRING  text
*----------------------------------------------------------------------*
FORM prepare_attachment USING p_wa_xstring.

  DATA:lt_fcat TYPE lvc_t_fcat.
  FIELD-SYMBOLS: <fs_data> TYPE ANY TABLE.

  GET REFERENCE OF i_ec_file INTO DATA(lo_data_log).
  ASSIGN lo_data_log->* TO <fs_data>.

  TRY.
      cl_salv_table=>factory(
        IMPORTING r_salv_table = DATA(lo_table)
        CHANGING  t_table      = <fs_data> ).

      lt_fcat = cl_salv_controller_metadata=>get_lvc_fieldcatalog(
                      r_columns      = lo_table->get_columns( )
                      r_aggregations = lo_table->get_aggregations( )
                      ).

      DELETE lt_fcat WHERE fieldname = 'MANDT' OR
                           fieldname = 'FGUID'.
      READ TABLE lt_fcat ASSIGNING FIELD-SYMBOL(<fs_fcat>) WITH KEY fieldname = 'FILENAME'.
      <fs_fcat>-reptext = 'File Name.'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'FILEDATE'.
      <fs_fcat>-reptext = 'File Date'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'FSTATUS'.
      <fs_fcat>-reptext = 'File Status'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'REMARKS'.
      <fs_fcat>-reptext = 'File Remarks'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'ERDAT'.
      <fs_fcat>-reptext = 'Created Date'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'ERZET'.
      <fs_fcat>-reptext = 'Created Time'.

      READ TABLE lt_fcat ASSIGNING <fs_fcat> WITH KEY fieldname = 'ERNAM'.
      <fs_fcat>-reptext = 'Created By'.

      DATA(lo_result) =
        cl_salv_ex_util=>factory_result_data_table(
          r_data         = lo_data_log
          t_fieldcatalog = lt_fcat ).

      cl_salv_bs_tt_util=>if_salv_bs_tt_util~transform(
        EXPORTING
          xml_type      = if_salv_bs_xml=>c_type_xlsx
          xml_version   = cl_salv_bs_a_xml_base=>get_version( )
          r_result_data = lo_result
          xml_flavour   = if_salv_bs_c_tt=>c_tt_xml_flavour_export
          gui_type      = if_salv_bs_xml=>c_gui_type_gui
        IMPORTING
          xml           = wa_xstring ).

    CATCH cx_root.
      CLEAR p_wa_xstring.
  ENDTRY.

  IF p_wa_xstring IS NOT INITIAL.
    OPEN DATASET lv_xls_file FOR OUTPUT IN BINARY MODE.
    IF sy-subrc EQ 0.
      TRANSFER p_wa_xstring TO lv_xls_file.
      CLOSE DATASET lv_xls_file.
    ENDIF.
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  VALIDATE_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM validate_data.

  DATA:
    lv_po_date TYPE zec_data-ecom_po_date,
    lv_werks   TYPE zec_data-werks,
    lv_matnr   TYPE zec_data-matnr,
    lv_charg   TYPE zec_data-charg,
    lv_meins   TYPE zec_data-meins,
    lv_kunwe   TYPE zec_data-kunwe,
    lv_lhs     TYPE zec_raw-rate,
    lv_rhs     TYPE zec_raw-rate,
    lv_rhs2    TYPE zec_raw-rate,
    lv_bool(1),
    lv_zmeng   TYPE string,
    lv_rate    TYPE string,
    lv_dotc    TYPE i.

  SORT i_ec_raw BY ecom_po ASCENDING.

  CLEAR w_ec_raw.
  LOOP AT i_ec_raw INTO w_ec_raw.
    DATA(lv_tabix) = sy-tabix.
    w_ec_mast-fguid = w_ec_raw-fguid.
    w_ec_mast-rguid = w_ec_raw-rguid.

    IF w_ec_raw-werks IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Plant Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      CLEAR: w_ec_file, lv_split2.
      READ TABLE i_ec_file INTO w_ec_file WITH KEY fguid = w_ec_raw-fguid.
      IF sy-subrc EQ 0.
        SPLIT w_ec_file-filename AT '_' INTO lv_split1 lv_split2 lv_split3 lv_split4.
        CONDENSE w_ec_raw-werks NO-GAPS.
        IF lv_split2 NE w_ec_raw-werks.
          CONCATENATE w_ec_raw-remarks 'Plant does not match with File Name,' INTO w_ec_raw-remarks SEPARATED BY space.
          CONDENSE w_ec_raw-remarks.
        ELSE.
          w_ec_mast-werks = w_ec_raw-werks.
        ENDIF.
      ENDIF.
    ENDIF.

    IF w_ec_raw-ecom_po IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Portal Order Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      IF w_ec_mast-werks IS NOT INITIAL.
        TRANSLATE w_ec_raw-ecom_po TO UPPER CASE. CLEAR lv_bool.
        SELECT SINGLE @abap_true FROM zec_data INTO @lv_bool
          WHERE ecom_po = @w_ec_raw-ecom_po
            AND werks   = @w_ec_mast-werks.
        IF sy-subrc EQ 0.
          CONCATENATE w_ec_raw-remarks 'Duplicate Portal Order,' INTO w_ec_raw-remarks SEPARATED BY space.
          CONDENSE w_ec_raw-remarks.
        ELSE.
          w_ec_mast-ecom_po = w_ec_raw-ecom_po.
        ENDIF.
      ENDIF.
    ENDIF.

    IF w_ec_raw-ecom_po_date IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'Port.Ord Date is empty,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_po_date = w_ec_raw-ecom_po_date.
      CALL FUNCTION 'DATE_CHECK_PLAUSIBILITY'
        EXPORTING
          date                      = lv_po_date
        EXCEPTIONS
          plausibility_check_failed = 1
          OTHERS                    = 2.
      IF sy-subrc <> 0.
        CONCATENATE w_ec_raw-remarks 'Invalid Date,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSE.
        w_ec_mast-ecom_po_date = lv_po_date.
      ENDIF.
    ENDIF.

    IF w_ec_raw-kunwe IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Ship-To-Party Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_kunwe = w_ec_raw-kunwe.
      lv_kunwe = |{ lv_kunwe ALPHA = IN }|. CLEAR lv_bool.
      SELECT SINGLE @abap_true FROM knvv INTO @lv_bool
        WHERE kunnr = @lv_kunwe.
      IF sy-subrc NE 0.
        CONCATENATE w_ec_raw-remarks 'Invalid Ship-To,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSE.
        w_ec_mast-kunwe = lv_kunwe.
      ENDIF.
    ENDIF.

    IF w_ec_raw-matnr IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Material Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_matnr = w_ec_raw-matnr.
      CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
        EXPORTING
          input        = lv_matnr
        IMPORTING
          output       = lv_matnr
        EXCEPTIONS
          length_error = 1
          OTHERS       = 2.

      CLEAR lv_bool.
      SELECT SINGLE @abap_true FROM mara INTO @lv_bool
        WHERE matnr = @lv_matnr.
      IF sy-subrc EQ 0.
        IF w_ec_mast-werks IS NOT INITIAL.
          CLEAR lv_bool.
          SELECT SINGLE @abap_true FROM marc INTO @lv_bool
            WHERE matnr = @lv_matnr
              AND werks = @w_ec_mast-werks.
          IF sy-subrc EQ 0.
            w_ec_mast-matnr = lv_matnr.
          ELSE.
            CONCATENATE w_ec_raw-remarks 'Material not extended to Plant,' INTO w_ec_raw-remarks SEPARATED BY space.
            CONDENSE w_ec_raw-remarks.
          ENDIF.
        ENDIF.
      ELSE.
        CONCATENATE w_ec_raw-remarks 'Invalid Material,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ENDIF.
    ENDIF.

    IF w_ec_raw-charg IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Batch Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_charg = w_ec_raw-charg.
      TRANSLATE lv_charg TO UPPER CASE. CLEAR lv_bool.
      IF w_ec_mast-werks IS NOT INITIAL AND w_ec_mast-matnr IS NOT INITIAL.
        SELECT SINGLE @abap_true FROM mcha INTO @lv_bool
          WHERE matnr = @w_ec_mast-matnr
            AND werks = @w_ec_mast-werks
            AND charg = @lv_charg.
        IF sy-subrc NE 0.
          CONCATENATE w_ec_raw-remarks 'Invalid Material Batch Combination,' INTO w_ec_raw-remarks SEPARATED BY space.
          CONDENSE w_ec_raw-remarks.
        ELSE.
          w_ec_mast-charg = lv_charg.
        ENDIF.
      ENDIF.
    ENDIF.

*Quantity Validations
    IF w_ec_raw-zmeng IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Quantity Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_zmeng = w_ec_raw-zmeng.
      FIND ALL OCCURRENCES OF '.' IN w_ec_raw-zmeng MATCH COUNT lv_dotc.
      IF lv_zmeng CN '0123456789.'.  "Contains Not Only.
        CONCATENATE w_ec_raw-remarks 'Invalid Quantity,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSEIF w_ec_raw-zmeng = '.'.
        CONCATENATE w_ec_raw-remarks 'Invalid Quantity,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
*        ENDIF.
      ELSEIF lv_dotc GT 1.
        CONCATENATE w_ec_raw-remarks 'Invalid Quantity,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSE.
        w_ec_mast-zmeng = CONV #( w_ec_raw-zmeng ).
      ENDIF.
    ENDIF.

*UOM Validations
    IF w_ec_raw-meins IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'Blank UOM,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_meins = w_ec_raw-meins.
      TRANSLATE lv_meins TO UPPER CASE.
      w_ec_mast-meins = lv_meins.
    ENDIF.

*Rate Validations
    CLEAR lv_dotc.
    IF w_ec_raw-rate IS INITIAL.
      CONCATENATE w_ec_raw-remarks 'No Rate Entered,' INTO w_ec_raw-remarks SEPARATED BY space.
      CONDENSE w_ec_raw-remarks.
    ELSE.
      lv_rate = w_ec_raw-rate.
      FIND ALL OCCURRENCES OF '.' IN w_ec_raw-rate MATCH COUNT lv_dotc.
      IF lv_rate CN '0123456789.'.  "Contains Not Only.
        CONCATENATE w_ec_raw-remarks 'Invalid Rate,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSEIF w_ec_raw-rate = '.'.    "Cannot contain only '.'
        CONCATENATE w_ec_raw-remarks 'Invalid Rate,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSEIF lv_dotc GT 1.           "Cannot contain more than one '.'
        CONCATENATE w_ec_raw-remarks 'Invalid Rate,' INTO w_ec_raw-remarks SEPARATED BY space.
        CONDENSE w_ec_raw-remarks.
      ELSE.
        w_ec_mast-rate = CONV #( w_ec_raw-rate ).
      ENDIF.
    ENDIF.

*Existing Validations from Wareiq which Ameeth suggested.
*        IF w_ec_raw-rate IS NOT INITIAL AND ( w_ec_raw-rate CA '-' ).
*          REPLACE ALL OCCURRENCES OF '-' IN w_ec_raw-rate WITH '0'.
*          CONDENSE w_ec_raw-rate NO-GAPS.
*        ENDIF.
*
*        IF w_ec_raw-rate IS NOT INITIAL AND ( w_ec_raw-rate CA ',' ).
*          REPLACE ALL OCCURRENCES OF ',' IN w_ec_raw-rate WITH space.
*          CONDENSE w_ec_raw-rate NO-GAPS.
*        ENDIF.

    IF w_ec_raw-ecom_cust IS NOT INITIAL.
      w_ec_mast-ecom_cust = w_ec_raw-ecom_cust.
    ENDIF.

    IF w_ec_raw-ecom_inv IS NOT INITIAL.
      TRANSLATE w_ec_raw-ecom_inv TO UPPER CASE.
      w_ec_mast-ecom_inv = w_ec_raw-ecom_inv.
    ENDIF.

*This check is removed because functional want to allow any number of Duplicate Material, Batch Entries in a File.
*    READ TABLE i_ec_mast_tmp WITH KEY ecom_po = w_ec_mast-ecom_po
*                                      werks = w_ec_mast-werks
*                                      matnr = w_ec_mast-matnr
*                                      charg = w_ec_mast-charg TRANSPORTING NO FIELDS.
*    IF sy-subrc EQ 0.
*      CONCATENATE w_ec_raw-remarks 'Duplicate Material+Batch in PO,' INTO w_ec_raw-remarks SEPARATED BY space.
*      CONDENSE w_ec_raw-remarks.
*    ENDIF.

    w_ec_raw-aedat = sy-datum.
    w_ec_raw-aezet = sy-uzeit.
    w_ec_raw-aenam = sy-uname.
    w_ec_mast-erdat = sy-datum.
    w_ec_mast-erzet = sy-uzeit.
    w_ec_mast-ernam = sy-uname.

    IF w_ec_raw-remarks IS NOT INITIAL.
      w_ec_raw-status = 'FAILED'.
    ELSE.
      w_ec_raw-status = 'UPLOADED'.
    ENDIF.

    IF w_ec_raw-remarks IS NOT INITIAL.
      DATA(lv_len) = strlen( w_ec_raw-remarks ).
      DATA(lv_last) = lv_len - 1.
      TRY.
          IF w_ec_raw-remarks+lv_last(lv_last) = ','.
            w_ec_raw-remarks+lv_last(lv_last) = ''.
          ENDIF.
        CATCH cx_root.
      ENDTRY.
      CONDENSE w_ec_raw-remarks.
    ENDIF.

    APPEND w_ec_mast TO i_ec_mast_tmp.
    MODIFY i_ec_raw FROM w_ec_raw INDEX lv_tabix TRANSPORTING remarks status aedat aezet aenam .
    CLEAR: w_ec_mast, w_ec_raw, lv_zmeng, lv_dotc.
  ENDLOOP.

*Move only those records where all items of PO are valid and no error.
  MOVE-CORRESPONDING i_ec_raw TO i_ecom_po.
  DELETE ADJACENT DUPLICATES FROM i_ecom_po COMPARING ecom_po
                                                      werks. "Santosh CI# INC0105527
  DELETE i_ecom_po WHERE ecom_po IS INITIAL.

  CLEAR w_ec_mast.
  LOOP AT i_ecom_po INTO DATA(w_ecom_po).
    READ TABLE i_ec_raw WITH KEY ecom_po = w_ecom_po-ecom_po
                                 werks   = w_ecom_po-werks  "Santosh CI# INC0105527
                                 status  = 'FAILED' TRANSPORTING NO FIELDS.
    IF sy-subrc NE 0.
      TRANSLATE w_ecom_po-ecom_po TO UPPER CASE.
      LOOP AT i_ec_mast_tmp INTO w_ec_mast WHERE ecom_po = w_ecom_po-ecom_po
                                             AND werks   = w_ecom_po-werks. "Santosh CI# INC0105527
        APPEND w_ec_mast TO i_ec_mast.
        CLEAR w_ec_mast.
      ENDLOOP.
    ENDIF.
  ENDLOOP.

  MODIFY zec_data FROM TABLE i_ec_mast.
  MODIFY zec_raw FROM TABLE i_ec_raw.
  COMMIT WORK.

ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  CREATE_SO_ORDER
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM create_docs.
*Begin of MOD01(+)
  TYPES: BEGIN OF ty_item,
           material   TYPE matnr,
           batch      TYPE charg_d,
           plant      TYPE werks_d,
           store_loc  TYPE lgort_d,
           target_qty TYPE dzmeng,
         END OF ty_item.
  TYPES: BEGIN OF ty_error,
           error TYPE char100,
         END OF ty_error.
  DATA: lt_item   TYPE TABLE OF ty_item,
        lt_itm    TYPE TABLE OF ty_item,
        ls_item   TYPE ty_item,
        lt_error  TYPE TABLE OF ty_error,
        ls_error  TYPE ty_error,
        lv_bstock TYPE char1.
*End of MOD01(+)
*Clearing these tables to save memory. When uploading 21k records, job is dumping with error no more memory available.
  CLEAR:i_ec_raw, i_ec_file, wa_xstring, i_ec_mast_tmp, i_ecom_po.

  DATA: r_spart TYPE RANGE OF mara-spart.

  IF i_ec_mast IS NOT INITIAL.

    SELECT SINGLE zcode_cmmt FROM zcode_mstr INTO @DATA(lv_auart)
      WHERE zcode_fldname = 'WAREIQ'
        AND zcode_value = 'AUART'.

    SELECT SINGLE zcode_cmmt FROM zcode_mstr INTO @DATA(lv_kschl)
      WHERE zcode_fldname = 'WAREIQ'
        AND zcode_value = 'KSCHL'.

    SELECT SINGLE zcode_cmmt FROM zcode_mstr INTO @DATA(lv_vkorg)
      WHERE zcode_fldname = 'WAREIQ'
        AND zcode_value = 'VKORG'.

    SELECT SINGLE zcode_cmmt FROM zcode_mstr INTO @DATA(lv_vtweg)
      WHERE zcode_fldname = 'WAREIQ'
        AND zcode_value = 'VTWEG'.

    SELECT SINGLE zcode_cmmt FROM zcode_mstr INTO @DATA(lv_waers)
      WHERE zcode_fldname = 'WAREIQ'
        AND zcode_value = 'WAERS'.

*For FOR ALL ENTRIES LHS and RHS should be same type
    MOVE-CORRESPONDING i_ec_mast TO i_werks.
    DELETE ADJACENT DUPLICATES FROM i_werks COMPARING werks.

    IF i_werks IS NOT INITIAL.
      SELECT zcode_fldname,
             zcode_value,
             zcode_cmmt,
             zcode_cmmt_1
        FROM zcode_mstr INTO TABLE @i_sold_to
        FOR ALL ENTRIES IN @i_werks
        WHERE zcode_fldname = 'WAREIQ'
          AND zcode_cmmt = @i_werks-werks.

      IF sy-subrc EQ 0.
        SELECT kunnr,
               vkorg,
               vtweg,
               spart,
               vwerk,
               vkgrp,
               vkbur,
               zterm
          FROM knvv INTO TABLE @DATA(i_knvv)
          FOR ALL ENTRIES IN @i_sold_to
          WHERE kunnr = @i_sold_to-zcode_value
            AND vwerk = @i_sold_to-zcode_cmmt
            AND vkorg = @lv_vkorg
            AND vtweg = @lv_vtweg.
      ENDIF.
    ENDIF.

    SELECT kunnr,
           katr2
      FROM kna1 INTO TABLE @DATA(i_kna1)
      FOR ALL ENTRIES IN @i_ec_mast
      WHERE kunnr = @i_ec_mast-kunwe.

    SELECT matnr,
           spart
      FROM mara INTO TABLE @DATA(i_mara)
      FOR ALL ENTRIES IN @i_ec_mast
      WHERE matnr = @i_ec_mast-matnr.

    LOOP AT i_ec_mast INTO w_ec_mast.
      READ TABLE i_mara INTO DATA(w_mara) WITH KEY matnr = w_ec_mast-matnr.
      IF sy-subrc EQ 0.
        w_po_div-ecom_po = w_ec_mast-ecom_po.
        w_po_div-werks   = w_ec_mast-werks.  "Santosh CI# INC0105527
        w_po_div-spart   = w_mara-spart.
        APPEND w_po_div TO i_po_div.
        CLEAR w_po_div.
      ENDIF.
    ENDLOOP.

    SORT i_po_div BY ecom_po
                     werks     "Santosh CI# INC0105527
                     spart.
    DELETE ADJACENT DUPLICATES FROM i_po_div COMPARING ecom_po
                                                       werks    "Santosh CI# INC0105527
                                                       spart.

    r_spart = VALUE #( FOR wa_mara IN i_mara
                         ( sign = 'I'
                           option = 'EQ'
                           low = wa_mara-spart
                          ) ).

    SORT r_spart BY low.
    DELETE ADJACENT DUPLICATES FROM r_spart COMPARING low.
    DELETE i_knvv WHERE spart NOT IN r_spart.

*Begin of MOD01(+)
    IF i_ec_mast[] IS NOT INITIAL.
      SELECT matnr,
             werks,
             lgort,
             charg,
             clabs
        FROM mchb
        INTO TABLE @DATA(lt_mchb)
         FOR ALL ENTRIES IN @i_ec_mast
       WHERE matnr = @i_ec_mast-matnr
         AND werks = @i_ec_mast-werks
         AND charg = @i_ec_mast-charg
         AND lvorm = @space.
      IF sy-subrc EQ 0.
        SORT: lt_mchb BY matnr werks lgort charg.
      ENDIF.
    ENDIF.
*End of MOD01(+)

*    MOVE-CORRESPONDING i_ec_mast TO i_ecom_po.
*    SORT i_ecom_po BY ecom_po.
*    DELETE ADJACENT DUPLICATES FROM i_ecom_po COMPARING ecom_po.

*    LOOP AT i_ecom_po INTO DATA(w_ecom_po).
    CLEAR w_po_div.
    LOOP AT i_po_div INTO w_po_div.
      w_item_no = 1.

      CLEAR: g_guid, i_ec_mast_tmp, i_ord_cond_in, i_ret_ord, g_delivery, g_guid, g_guid2, g_invoice,
 g_msg, g_pgidoc, i_dlvref, i_ec_log, i_ord_cond_inx, i_ord_itm_in, i_ord_itm_inx, i_ord_part,
 i_ord_schd_in, i_ord_schd_inx, i_prot, i_ret_ord, w_dlvref, w_ec_log, w_ord_head_in,
 w_ord_head_inx, w_pgidata, g_sales_ord, i_billingdata, w_billingdata, i_return_bill, i_success, i_lips, i_mseg, i_vbrp.
      "i_vbap
      LOOP AT i_ec_mast INTO w_ec_mast WHERE ecom_po = w_po_div-ecom_po
                                         AND werks   = w_po_div-werks.  ""Santosh CI# INC0105527

        READ TABLE i_mara INTO w_mara WITH KEY matnr = w_ec_mast-matnr
                                               spart = w_po_div-spart.
        IF sy-subrc EQ 0.
          w_ord_head_in-division = w_mara-spart.

          w_ord_head_in-doc_type   = lv_auart.
          w_ord_head_in-sales_org  = lv_vkorg.
          w_ord_head_in-distr_chan = lv_vtweg.

          w_ord_head_in-purch_date = w_ec_mast-ecom_po_date.
          w_ord_head_in-purch_no_c = w_ec_mast-ecom_po.
          w_ord_head_in-ref_1      = w_ec_mast-ecom_cust.
          w_ord_head_in-purch_no_s = w_ec_mast-ecom_inv.

          w_ord_part-partn_role = 'WE'.
          w_ord_part-partn_numb = w_ec_mast-kunwe.
          APPEND w_ord_part TO i_ord_part.
          CLEAR w_ord_part.

          READ TABLE i_kna1 INTO DATA(w_kna1) WITH KEY kunnr = w_ec_mast-kunwe.
          IF sy-subrc = 0.
            CLEAR w_sold_to.
            READ TABLE i_sold_to INTO w_sold_to WITH KEY zcode_cmmt = w_ec_mast-werks
                                                         zcode_cmmt_1 = w_kna1-katr2.
            IF sy-subrc EQ 0.
              w_ord_part-partn_role = 'AG'.
              w_ord_part-partn_numb = w_sold_to-zcode_value.
              APPEND w_ord_part TO i_ord_part.
              CLEAR:w_kna1, w_ord_part.
            ENDIF.
          ELSE.
            CLEAR w_sold_to.
            READ TABLE i_sold_to INTO w_sold_to WITH KEY zcode_value = w_ec_mast-werks.
            IF sy-subrc EQ 0.
              w_ord_part-partn_role = 'AG'.
              w_ord_part-partn_numb = w_sold_to-zcode_cmmt.
              APPEND w_ord_part TO i_ord_part.
              CLEAR:i_kna1, w_ord_part.
            ENDIF.
          ENDIF.

          READ TABLE i_knvv INTO DATA(w_knvv) WITH KEY kunnr = w_sold_to-zcode_value
                                                       vwerk = w_sold_to-zcode_cmmt
                                                       vkorg = lv_vkorg
                                                       vtweg = lv_vtweg
                                                       spart = w_mara-spart.
          IF sy-subrc EQ 0.
            w_ord_head_in-sales_grp = w_knvv-vkgrp.
            w_ord_head_in-sales_off = w_knvv-vkbur.
            w_ord_head_in-pmnttrms  = w_knvv-zterm.
          ENDIF.

          w_ord_head_inx-doc_type   = 'X'.
          w_ord_head_inx-sales_org  = 'X'.
          w_ord_head_inx-distr_chan = 'X'.
          w_ord_head_inx-division   = 'X'.
          w_ord_head_inx-sales_grp  = 'X'.
          w_ord_head_inx-sales_off  = 'X'.
          w_ord_head_inx-pmnttrms   = 'X'.
          w_ord_head_inx-purch_no_c = 'X'.
          w_ord_head_inx-purch_date = 'X'.
          w_ord_head_inx-ref_1      = 'X'.
          w_ord_head_inx-purch_no_s = 'X'.

          w_item_no2 = w_item_no * 10.
          w_ord_itm_in-itm_number = w_item_no2.
          w_ord_itm_in-material   = w_ec_mast-matnr.
          w_ord_itm_in-plant      = w_ec_mast-werks.
          w_ord_itm_in-batch      = w_ec_mast-charg.
