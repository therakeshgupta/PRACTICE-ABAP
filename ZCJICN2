    DATA : lv_psphi1 TYPE string.
    TYPES : BEGIN OF ty_prps3,
              pspnr   TYPE prps-pspnr,
              posid   TYPE prps-posid,
              objnr   TYPE prps-objnr,
              psphi   TYPE prps-psphi,
              psphi_c TYPE char8,
              usr08   TYPE prps-usr08,
              usr09   TYPE prps-usr09,
              usr00   TYPE prps-usr00,
            END OF ty_prps3.
    DATA : lt_prps3 TYPE STANDARD TABLE OF ty_prps3,
           ls_prps3 TYPE ty_prps3.
    REFRESH : lt_prps3.
    SELECT pspnr, posid, objnr, psphi, usr00, usr08, usr09
    INTO TABLE @DATA(lt_prps1)
    FROM prps FOR ALL ENTRIES IN @it_final
    WHERE posid = @it_final-posid.
    IF sy-subrc = 0 AND lt_prps1 IS NOT INITIAL.

      SELECT posid, objnr, psphi, usr00, usr08, usr09
      INTO TABLE @DATA(lt_prps2)
      FROM prps FOR ALL ENTRIES IN @lt_prps1
      WHERE psphi = @lt_prps1-psphi.
      SORT lt_prps2 BY objnr.     ""Added by Rakesh for WO#4030 on 05.04.2023.
      IF sy-subrc = 0.
        LOOP AT lt_prps1 INTO DATA(ls_prps_tmp).
          CLEAR : lv_psphi1.
          lv_psphi1 = ls_prps_tmp-psphi.
          CALL FUNCTION 'CONVERSION_EXIT_KONPD_OUTPUT'
            EXPORTING
              input  = lv_psphi1
            IMPORTING
              output = lv_psphi1.
          MOVE-CORRESPONDING ls_prps_tmp TO ls_prps3.
          READ TABLE lt_prps2 INTO DATA(ls_prps0) WITH KEY posid = lv_psphi1.
          IF sy-subrc = 0.
            ls_prps3-usr00 = ls_prps0-usr00.
          ENDIF.
          ls_prps3-psphi_c = lv_psphi1.
          READ TABLE lt_prps2 INTO DATA(ls_prps2) WITH KEY psphi = ls_prps_tmp-psphi.
          IF sy-subrc = 0.
            IF ls_prps2-usr08 NE '00000000'.
              ls_prps3-usr08 = ls_prps2-usr08.
            ENDIF.
            IF ls_prps2-usr09 NE '00000000'.
              ls_prps3-usr09 = ls_prps2-usr09.
            ELSEIF ls_prps3-usr08 NE '00000000'.
              ls_prps3-usr09 = ls_prps3-usr08.
            ENDIF.

            IF ls_prps3-usr08 = '00000000'.
              SELECT SINGLE pspid, plsez FROM proj INTO @DATA(ls_proj1)
              WHERE pspnr = @ls_prps3-psphi.
*          IF sy-subrc = 0.                                       ""Commented by Rakesh for WO# 4030 on 04.04.2023
              IF sy-subrc = 0 AND ls_proj1-plsez NE '00000000'.    ""Added by Rakesh for WO# 4030 on 04.04.2023
                ls_prps3-usr08 = ls_proj1-plsez.
                IF ls_prps3-usr09 = '00000000'.
                  ls_prps3-usr09 = ls_proj1-plsez.
                ENDIF.
              ENDIF.
            ENDIF.

          ELSE.
            ls_prps3-usr00 = ls_prps2-usr00.
            SELECT SINGLE pspid, plsez FROM proj INTO @DATA(ls_proj)
            WHERE pspid = @ls_prps3-psphi.
*          IF sy-subrc = 0.                                     ""Commented by Rakesh for WO# 4030 on 04.04.2023
            IF sy-subrc = 0 AND ls_proj-plsez NE '00000000'.    ""Added by Rakesh for WO# 4030 on 04.04.2023
              ls_prps3-usr08 = ls_proj-plsez.
              IF ls_prps3-usr09 NE '00000000'.
                ls_prps3-usr09 = ls_proj-plsez.
              ENDIF.
            ENDIF.
          ENDIF.
          APPEND ls_prps3 TO lt_prps3.
          CLEAR : ls_prps_tmp, ls_prps0, ls_prps3, ls_proj, ls_proj1.
        ENDLOOP.
      ENDIF.
    ENDIF.

    IF lt_prps3 IS NOT INITIAL.
      SELECT pspnr, pspid, vbukr, vgsbr, prctr INTO TABLE @DATA(lt_proj2)
        FROM proj FOR ALL ENTRIES IN @lt_prps3
        WHERE pspnr = @lt_prps3-psphi.
      IF sy-subrc NE 0.
