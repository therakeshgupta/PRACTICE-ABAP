    DATA(lv_index) = 0.

    LOOP AT it_final INTO DATA(ls_final).
      lv_index = lv_index + 1.
      READ TABLE lt_prps3 INTO ls_prps3 WITH KEY psphi_c = ls_final-cer_no.
      IF sy-subrc = 0.
        CLEAR : ls_final-usr00.
        ls_final-usr00  = ls_prps3-usr00.
*        ls_final-plan_ageing = ls_prps3-usr08 - sy-datum.
*        IF p_dat IS NOT INITIAL.
*          ls_final-plan_ageing_d = ls_prps3-usr08 - p_dat.
*        ENDIF.
        IF ls_prps3-usr08 NE '00000000'.
          CONCATENATE ls_prps3-usr08+6(2) ls_prps3-usr08+4(2) ls_prps3-usr08+0(4) INTO ls_final-usr08 SEPARATED BY '.'.
        ENDIF.
        IF ls_prps3-usr09 NE '00000000'.
          CONCATENATE ls_prps3-usr09+6(2) ls_prps3-usr09+4(2) ls_prps3-usr09+0(4) INTO ls_final-usr09 SEPARATED BY '.'.
        ENDIF.
      ELSE.
        CLEAR : ls_final-usr00, ls_prps3.
      ENDIF.

      READ TABLE lt_proj2 INTO DATA(ls_proj2) WITH KEY pspid = ls_final-cer_no.
      IF sy-subrc = 0.
        CLEAR : ls_final-vbukr, ls_final-vgsbr, ls_final-prctr.
        ls_final-vbukr = ls_proj2-vbukr.
        ls_final-vgsbr = ls_proj2-vgsbr.
